{
  // Publish-only build: emit JS + .d.ts into dist/ for npm consumers (e.g. avcshub).
  // Development and tests still run the raw .ts via `node --experimental-strip-types`
  // (see tsconfig.json / package.json scripts) — this config exists ONLY to produce the
  // distributable artifact. Source keeps `.ts` import specifiers (which the type-strip
  // runtime needs); `rewriteRelativeImportExtensions` rewrites them to `.js` on emit so
  // the compiled output resolves correctly from node_modules.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "rewriteRelativeImportExtensions": true
  },
  // The MCP server (src/mcp/**) IS part of the shipped artifact: it is avcs's primary,
  // agent-facing interface, reached via `avcs mcp`. It only loads `@modelcontextprotocol/sdk`
  // (an optionalDependency) lazily at runtime, so the core library import paths stay dep-free
  // even though dist/mcp/server.js is present. `demo.ts` and tests are still dev-only.
  "include": ["src/**/*.ts"],
  "exclude": ["src/demo.ts", "test/**", "**/*.test.ts", "bench/**"]
}
